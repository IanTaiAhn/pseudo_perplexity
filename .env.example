ANTHROPIC_API_KEY=your_anthropic_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key_here
LANGFUSE_SECRET_KEY=your_langfuse_secret_key_here
LANGFUSE_HOST=https://cloud.langfuse.com
CHROMA_PERSIST_DIR=./chroma_db
MAX_INPUT_TOKENS=50000
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
LLM_MODEL=claude-sonnet-4-6
# Set LOCAL_LLM_MODEL to use a local HuggingFace model instead of Claude.
# The model must already be downloaded. Example:
# LOCAL_LLM_MODEL=Qwen/Qwen2.5-1.5B-Instruct

# Layer 4 — RAGAS eval (evaluation/ragas_runner.py). Requires ANTHROPIC_API_KEY
# above regardless of LOCAL_LLM_MODEL — a small local model is a weak judge for
# faithfulness/relevance scoring, so eval always uses a real Claude call.
# Optional: which model RAGAS uses as its judge LLM. Defaults to LLM_MODEL.
# RAGAS_LLM_MODEL=claude-sonnet-4-6
# MLflow needs no env var here — it defaults to a local ./mlruns file store.

# Layer 5 — Observability
# structlog output level. One of DEBUG/INFO/WARNING/ERROR (see spec section 9).
LOG_LEVEL=INFO
# Where monitoring/drift_detector.py persists logged query embeddings and the
# frozen baseline snapshot. Mounted as a volume in docker-compose.yml so it
# survives container restarts.
MONITORING_DATA_DIR=monitoring/data
# LANGFUSE_PUBLIC_KEY/LANGFUSE_SECRET_KEY above are optional: if either is
# unset, synthesis/generator.py skips Langfuse tracing entirely (no signup
# required to run the system). Get free-tier keys at https://cloud.langfuse.com
# if you want traces, or leave unset and rely on structlog + Prometheus.
# Prometheus scrapes GET /metrics on the app container (see infra/prometheus.yml).
# Grafana (http://localhost:3000, admin/admin) auto-loads the dashboard from
# infra/grafana/provisioning/ — no manual setup needed after docker-compose up.

ANTHROPIC_API_KEY=your_anthropic_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key_here
LANGFUSE_SECRET_KEY=your_langfuse_secret_key_here
LANGFUSE_HOST=https://cloud.langfuse.com
CHROMA_PERSIST_DIR=./chroma_db
MAX_INPUT_TOKENS=50000
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
LLM_MODEL=claude-sonnet-4-6
# Set LOCAL_LLM_MODEL to use a local HuggingFace model instead of Claude.
# The model must already be downloaded. Example:
# LOCAL_LLM_MODEL=Qwen/Qwen2.5-1.5B-Instruct

# Behind a corporate TLS-inspecting proxy? Point this at your proxy's root CA
# bundle (.pem) so outbound httpx requests (Tavily, URL fetching) can verify
# the intercepted certificate chain. Only set this to "false" as a last
# resort — it disables certificate verification entirely, including on the
# request that carries your Tavily API key.
# HTTPX_SSL_VERIFY=/path/to/corporate-ca-bundle.pem

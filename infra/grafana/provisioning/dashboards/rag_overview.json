{
  "title": "Pseudo-Perplexity — RAG Overview",
  "uid": "rag-overview",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "timezone": "browser",
  "time": { "from": "now-24h", "to": "now" },
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Query rate",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
      "targets": [
        { "expr": "rate(query_total[5m])", "legendFormat": "queries/sec", "refId": "A" }
      ]
    },
    {
      "id": 2,
      "title": "Error rate",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
      "targets": [
        { "expr": "sum by (error_type) (rate(error_total[5m]))", "legendFormat": "{{error_type}}", "refId": "A" }
      ]
    },
    {
      "id": 3,
      "title": "End-to-end query latency (P50 / P95)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(query_latency_seconds_bucket[5m])) by (le))", "legendFormat": "P50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum(rate(query_latency_seconds_bucket[5m])) by (le))", "legendFormat": "P95", "refId": "B" }
      ]
    },
    {
      "id": 4,
      "title": "Retrieval vs LLM latency (P95)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(retrieval_latency_seconds_bucket[5m])) by (le))", "legendFormat": "retrieval P95", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum(rate(llm_latency_seconds_bucket[5m])) by (le))", "legendFormat": "llm P95", "refId": "B" }
      ]
    },
    {
      "id": 5,
      "title": "Retrieval hit rate",
      "type": "gauge",
      "gridPos": { "x": 0, "y": 16, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "green", "value": 0.8 }
            ]
          }
        }
      },
      "targets": [
        { "expr": "retrieval_hit_rate", "refId": "A" }
      ]
    },
    {
      "id": 6,
      "title": "Cost per query (5m avg)",
      "type": "stat",
      "gridPos": { "x": 8, "y": 16, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
      "fieldConfig": { "defaults": { "unit": "currencyUSD" } },
      "targets": [
        { "expr": "rate(llm_cost_usd_total[5m]) / rate(query_total[5m])", "refId": "A" }
      ]
    },
    {
      "id": 7,
      "title": "Cost — last 24h total",
      "type": "stat",
      "gridPos": { "x": 16, "y": 16, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
      "fieldConfig": { "defaults": { "unit": "currencyUSD" } },
      "targets": [
        { "expr": "increase(llm_cost_usd_total[24h])", "refId": "A" }
      ]
    },
    {
      "id": 8,
      "title": "Token throughput by direction",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 24, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
      "targets": [
        { "expr": "sum by (direction) (rate(llm_tokens_total[5m]))", "legendFormat": "{{direction}}", "refId": "A" }
      ]
    }
  ]
}
